# Copy this file to .env and fill in real values. Never commit the real .env.

# --- App ---
ENVIRONMENT=development
DEBUG=true

# --- Database (Supabase) ---
SUPABASE_URL=
SUPABASE_KEY=
DATABASE_URL=sqlite:///./dukastock_dev.db

# --- Redis (Upstash) ---
REDIS_URL=redis://localhost:6379/0
USSD_SESSION_TTL_SECONDS=180

# --- Twilio (WhatsApp sandbox) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- Africa's Talking (USSD + SMS, Rwanda: MTN & Airtel) ---
AT_USERNAME=sandbox
AT_API_KEY=
AT_USSD_CODE=*384*00#
AT_SENDER_ID=DukaStock

# --- Privacy (Rwanda Law No. 058/2021) ---
# Generate a long random string for production. Never reuse this default.
PHONE_HASH_SALT=change-me-in-production

# --- ML ---
MODEL_ARTIFACT_DIR=ml_experiments/artifacts
FORECAST_HORIZON_DAYS=7

# --- NLP ---
NER_MODEL_DIR=app/nlp/xlmr_commerce_ner
NER_CONFIDENCE_THRESHOLD=0.55
